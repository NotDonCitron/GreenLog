# =============================================
# GreenLog — Environment Variables
# =============================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control!

# --- Supabase (Required) ---
# Get these from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_xxxx    # Public key — safe in browser
SUPABASE_SERVICE_ROLE_KEY=sb_xxxx        # Server-only key — NEVER expose to client!

# --- Sentry (after `npx sentry-wizard@latest -i nextjs`) ---
# Get these from: Sentry Dashboard > Settings > Projects > [Project] > Client Keys
SENTRY_ORG=your-org
SENTRY_PROJECT=greenlog-app
SENTRY_AUTH_TOKEN=xxxx                   # CI/CD only — NOT in .env.local!
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx  # Public, OK in .env.local

# --- Clerk Authentication (Primary Auth Provider) ---
# Get these from: Clerk Dashboard > API Keys
# https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_xxxxxx                                            # Backend-only - NEVER commit to git!
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_xxxxxx                           # Public key - safe in browser

# --- Push Notifications (VAPID) ---
# Generate once with: npx web-push generate-vapid-keys
# Keep PRIVATE_KEY server-side only (service role)!
VAPID_PUBLIC_KEY=BCh6V8K7HR...   # Public - safe for browser
VAPID_PRIVATE_KEY=  # PRIVATE - NEVER expose to client!

# --- Optional APIs ---
# MiniMax API key (if AI features are used)
MINIMAX_API_KEY=sk-xxxx

# GitHub token (for CI/CD workflows)
GITHUB_TOKEN=ghp_xxxx

# --- App Configuration ---
# Comma-separated user IDs with admin privileges (can override strain images)
# Find User IDs in: Supabase Dashboard > Authentication > Users > copy the UUID
APP_ADMIN_IDS=6129fd73-ec07-4551-ba32-3c8ef5c5923a,dab750b5-8023-45d6-844e-b044b681905c,2d797325-5a17-4620-8b94-a55f338996c1

# Comma-separated user IDs allowed to create feedback tickets
FEEDBACK_ALLOWED_CREATOR_IDS=user-id-1,user-id-2

# --- URLs ---
NEXT_PUBLIC_SITE_URL=https://greenlog.app

# --- Playwright E2E Testing (Cloudflare Turnstile Bypass) ---
# Testing keys from https://developers.cloudflare.com/turnstile/testing/
# Add to .env.local for local E2E tests — NEVER commit real keys!
TURNSTILE_TEST_KEY=1x00000000000000000000AA
TURNSTILE_TEST_SECRET=1x0000000000000000000000000000000AA

# --- Supabase Local AI SQL Assistant ---
# Enables AI features in Supabase Studio local docker stack
# Get from: Supabase Dashboard > Project Settings > AI
# NOTE: Use MINIMAX_API_KEY (already defined above) for local Supabase Studio
# OPENAI_KEY=sk-xxxx  # Not used — we have MINIMAX_API_KEY instead

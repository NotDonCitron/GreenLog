scripts/.fill-missing-images-lock.json
scripts/.image-pipeline-lock.json
*.json
!package.json
!tsconfig.json

# strain images (stored in Supabase storage, not needed for deploy)
public/strains/

# android / capacitor (not deployed)
android/

# build output
out/

# dev docs
docs/strains-missing-images.md

# migration files (can be re-created)
supabase/migrations/*.sql

# helper scripts
scripts/check-*.mjs
scripts/firecrawl-*.mjs
scripts/playwright-*.mjs
scripts/cleanup-*.mjs
scripts/retry-*.mjs
scripts/upload-missing-strain-images.mjs
scripts/test-upload-check.mjs
.env*.local

# clerk configuration (can include secrets)
/.clerk/
.next_old/
.worktrees/

# planning & brainstorming (internal, never commit)
.planning/
.superpowers/
brainstorm/
age_gate_output.html
curl_out.txt
dev_error_log.txt
dev_log2.txt
server_pid.txt

